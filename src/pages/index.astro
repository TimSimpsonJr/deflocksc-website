---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import MapSection from '../components/MapSection.astro';
import BillTracker from '../components/BillTracker.astro';
import FAQ from '../components/FAQ.astro';
import TakeAction from '../components/TakeAction.astro';
---

<Base title="DeflockSC — Stop Surveillance in Upstate SC">
  <Hero />
  <HowItWorks />
  <MapSection />
  <BillTracker />

  <section class="bg-[#171717] py-12">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-[#a3a3a3] text-base mb-4">Ready to take the next step?</p>
      <a href="/toolkit" class="inline-block bg-[#dc2626] hover:bg-[#b91c1c] text-white font-bold text-sm uppercase tracking-[0.1em] px-6 py-3 rounded transition-colors">
        Open the Citizen Toolkit
      </a>
    </div>
  </section>

  <FAQ />
  <TakeAction />
</Base>
