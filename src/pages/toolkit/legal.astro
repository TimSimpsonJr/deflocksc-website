---
import Base from '../../layouts/Base.astro';
import ToolkitLegal from '../../components/ToolkitLegal.astro';

const title = "ALPR Laws in South Carolina — Know Your Rights | DeflockSC";
const description = "Fourth Amendment primer, state-by-state ALPR law comparison, and bill gap analysis for South Carolina's pending surveillance legislation.";

const siblings = [
  { href: '/toolkit/foia', label: 'Request Records' },
  { href: '/toolkit/speaking', label: 'Speak Up' },
  { href: '/toolkit/outreach', label: 'Spread the Word' },
];
---

<Base title={title} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://deflocksc.org/" },
      { "@type": "ListItem", "position": 2, "name": "Toolkit", "item": "https://deflocksc.org/toolkit" },
      { "@type": "ListItem", "position": 3, "name": "Know Your Rights", "item": "https://deflocksc.org/toolkit/legal" }
    ]
  })} />

  <section class="bg-[#111111] pt-24 pb-6">
    <div class="max-w-4xl mx-auto px-6">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 label-mono-nav">
          <li><a href="/" class="text-[#737373] hover:text-[#a3a3a3] transition-colors">Home</a></li>
          <li class="text-[#525252]">/</li>
          <li><a href="/toolkit" class="text-[#737373] hover:text-[#a3a3a3] transition-colors">Toolkit</a></li>
          <li class="text-[#525252]">/</li>
          <li class="text-[#e8e8e8]">Know Your Rights</li>
        </ol>
      </nav>
    </div>
  </section>

  <section class="bg-[#141414]">
    <div class="max-w-4xl mx-auto px-6 pb-20 md:pb-28">
      <ToolkitLegal />
    </div>
  </section>

  <section class="bg-[#111111] border-t border-[rgba(255,255,255,0.07)]">
    <div class="max-w-4xl mx-auto px-6 py-12">
      <p class="label-mono text-[#737373] mb-4">More from the Toolkit</p>
      <div class="flex flex-wrap gap-3">
        {siblings.map((s) => (
          <a href={s.href} class="label-mono-compact text-[#a3a3a3] hover:text-[#e8e8e8] border border-[rgba(255,255,255,0.07)] hover:border-[rgba(255,255,255,0.15)] px-4 py-2.5 transition-colors">
            {s.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
