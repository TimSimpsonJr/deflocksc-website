---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found — DeflockSC" description="The page you're looking for doesn't exist.">
  <section class="min-h-[80vh] flex items-center relative overflow-hidden">
    <div class="absolute left-4 top-1/2 -translate-y-1/2 font-bold leading-none text-[rgba(220,38,38,0.07)] pointer-events-none select-none" style="font-size: clamp(10rem, 22vw, 20rem)" aria-hidden="true">404</div>
    <div class="max-w-[900px] mx-auto px-6 md:px-12 relative z-10">
      <p class="label-mono text-[#737373] mb-3">Page not found</p>
      <h1 class="text-4xl md:text-6xl font-bold text-[#e8e8e8] tracking-[-0.02em] mb-6">Nothing here.</h1>
      <p class="text-[#a0a0a0] text-lg mb-10 max-w-lg">The page you're looking for doesn't exist or has been moved. Try heading back home or check the blog.</p>
      <div class="flex flex-col sm:flex-row items-start gap-4">
        <a href="/" class="inline-block bg-[#dc2626] hover:bg-[#b91c1c] text-white font-bold text-xs uppercase tracking-[0.08em] px-8 py-3.5 transition-colors">Back to Home</a>
        <a href="/blog" class="inline-block text-[#fbbf24] hover:text-[#fcd34d] font-medium text-xs uppercase tracking-[0.08em] px-8 py-3.5 transition-colors">Read the Blog</a>
      </div>
    </div>
  </section>
</Base>
