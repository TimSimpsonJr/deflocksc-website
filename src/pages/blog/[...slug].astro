---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={`${post.data.title} — DeflockSC`} description={post.data.summary}>
  <article class="py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6">
      <a href="/blog" class="text-[#ef4444] hover:text-[#dc2626] text-sm font-medium transition-colors mb-8 inline-block">&larr; Back to Blog</a>

      <header class="mb-10">
        <time class="text-[#64748b] text-sm font-medium" datetime={new Date(post.data.date).toISOString()}>
          {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="text-3xl md:text-4xl font-[900] text-white mt-2 leading-tight">{post.data.title}</h1>
      </header>

      <div class="prose prose-invert max-w-none
        [&>p]:text-[#cbd5e1] [&>p]:leading-[1.8] [&>p]:mb-6
        [&>h2]:text-white [&>h2]:font-bold [&>h2]:text-2xl [&>h2]:mt-10 [&>h2]:mb-4
        [&>h3]:text-white [&>h3]:font-bold [&>h3]:text-xl [&>h3]:mt-8 [&>h3]:mb-3
        [&>ul]:text-[#cbd5e1] [&>ul]:space-y-2 [&>ul]:mb-6 [&>ul>li]:pl-2
        [&>ol]:text-[#cbd5e1] [&>ol]:space-y-2 [&>ol]:mb-6
        [&>blockquote]:border-l-3 [&>blockquote]:border-[#ef4444] [&>blockquote]:pl-6 [&>blockquote]:text-[#94a3b8] [&>blockquote]:italic [&>blockquote]:my-8
        [&_a]:text-[#ef4444] [&_a]:hover:text-[#dc2626] [&_a]:transition-colors
        [&_strong]:text-white
        [&_code]:bg-[#1e293b] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm
        [&>pre]:bg-[#1e293b] [&>pre]:p-4 [&>pre]:rounded-lg [&>pre]:overflow-x-auto [&>pre]:mb-6
        [&_pre_code]:p-0 [&_pre_code]:bg-transparent">
        <Content />
      </div>
    </div>
  </article>
</Base>
