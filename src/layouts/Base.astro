---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ActionModal from '../components/ActionModal.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = "DeflockSC", description = "Bringing transparency to license plate surveillance in Upstate South Carolina." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <meta name="theme-color" content="#171717" />
    <link rel="alternate" type="application/rss+xml" title="DeflockSC Blog" href="/rss.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#171717] text-[#d4d4d4] font-['Inter',sans-serif] leading-[1.7] min-h-screen">
    <Nav />

    <main class="pt-16">
      <slot />
    </main>

    <Footer />
    <ActionModal />

    <script>
      function initSpotlights() {
        document.querySelectorAll<HTMLElement>('[data-spotlight]').forEach((card) => {
          card.addEventListener('mousemove', (e) => {
            const rect = card.getBoundingClientRect();
            card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
            card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
          });
        });
      }
      initSpotlights();
      document.addEventListener('astro:after-swap', initSpotlights);
    </script>
  </body>
</html>
