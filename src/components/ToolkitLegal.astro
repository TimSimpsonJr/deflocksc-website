---
import legalData from '../data/toolkit-legal.json';
import bills from '../data/bills.json';

const { fourthAmendment, otherStates, billGaps } = legalData;
---

<!-- Section 1: 4th Amendment Primer -->
<div class="mb-16">
  <h3 class="text-white font-extrabold text-xl md:text-2xl tracking-[-0.02em] mb-4">
    {fourthAmendment.title}
  </h3>
  <p class="text-[#d4d4d4] text-base leading-[1.7] mb-8">
    {fourthAmendment.intro}
  </p>

  <div class="space-y-3">
    {fourthAmendment.keyPoints.map((kp, i) => (
      <details class="legal-details group border-l-[3px] border-[#262626]" data-legal={i} open={i === 0 || undefined}>
        <summary class="flex items-center justify-between cursor-pointer py-4 px-5 list-none [&::-webkit-details-marker]:hidden">
          <span class="text-white font-bold text-base pr-4">{kp.point}</span>
          <span class="legal-icon text-[#ef4444] font-bold text-xl flex-shrink-0 transition-transform duration-300">+</span>
        </summary>
        <div class="legal-content">
          <div class="legal-inner px-5 pb-5">
            <p class="text-[#a3a3a3] text-base leading-[1.7]">{kp.detail}</p>
          </div>
        </div>
      </details>
    ))}
  </div>

  <p class="text-[#737373] text-xs mt-6 italic">
    {fourthAmendment.disclaimer}
  </p>
</div>

<!-- Section 2: Legal Landscape - Other States vs SC -->
<div class="mb-16">
  <h3 class="text-white font-extrabold text-xl md:text-2xl tracking-[-0.02em] mb-6">
    How Other States Compare
  </h3>
  <p class="text-[#d4d4d4] text-base leading-[1.7] mb-8">
    At least six states have passed laws restricting how license plate data is collected,
    stored, and shared. South Carolina has none.
  </p>

  <div class="space-y-3">
    {otherStates.map((entry) => {
      const isSC = entry.state === 'South Carolina';
      return (
        <div
          class:list={[
            'rounded-lg px-5 py-4',
            isSC
              ? 'bg-[rgba(239,68,68,0.12)] border-l-[3px] border-[#ef4444]'
              : 'bg-[rgba(163,163,163,0.12)]',
          ]}
        >
          <div class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-4">
            <span
              class:list={[
                'font-bold text-sm shrink-0 sm:w-36',
                isSC ? 'text-[#ef4444]' : 'text-white',
              ]}
            >
              {entry.state}
            </span>
            <span
              class:list={[
                'text-sm leading-[1.6]',
                isSC ? 'text-[#d4d4d4] font-medium' : 'text-[#a3a3a3]',
              ]}
            >
              {entry.law}
            </span>
          </div>
        </div>
      );
    })}
  </div>
</div>

<!-- Section 3: SC Bill Tracker (homepage-style interactive cards) -->
<div class="mb-16">
  <h3 class="text-white font-extrabold text-xl md:text-2xl tracking-[-0.02em] mb-6">
    SC Bill Tracker
  </h3>

  <div class="bg-[rgba(163,163,163,0.12)] rounded-xl p-5 md:p-6">
    <div class="space-y-4 mb-6">
      {bills.map((bill: any, i: number) => (
        <button
          type="button"
          class="tk-bill-card bg-[#171717] border-l-[3px] border-[#ef4444] rounded-r-md p-5 cursor-pointer transition-all duration-200 hover:bg-[#2e2e2e] hover:translate-x-1 focus-visible:bg-[#2e2e2e] focus-visible:translate-x-1 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#ef4444] focus-visible:ring-offset-2 focus-visible:ring-offset-[#171717] w-full text-left"
          data-tk-bill={i}
          aria-label={`${bill.bill}: ${bill.title}`}
        >
          <div class="flex flex-wrap items-start justify-between gap-x-4 gap-y-1 mb-2">
            <span class="text-[#ef4444] font-extrabold text-lg">{bill.bill}</span>
            <span class="text-[#fbbf24] font-bold text-[0.7rem] uppercase tracking-[0.05em] bg-[rgba(251,191,36,0.1)] px-3 py-1 rounded">
              {bill.status}
            </span>
          </div>
          <p class="text-[#d4d4d4] text-sm mb-2">{bill.title}</p>
          <p class="text-[#a3a3a3] text-xs font-medium">See what this bill would change &rarr;&#xFE0E;</p>
        </button>
      ))}
    </div>

    <p class="text-[#a3a3a3] text-sm mb-4">Last updated: February 2026</p>
    <p class="text-[#a3a3a3] text-sm leading-relaxed">
      <em>Bill status is checked automatically each week during the legislative session.</em>
    </p>
  </div>
</div>

<!-- Toolkit bill modal -->
<div id="tk-bill-backdrop" class="fixed inset-0 z-[100] bg-[rgba(10,10,10,0.85)] hidden opacity-0 transition-opacity duration-200 flex items-center justify-center p-5">
  <div id="tk-bill-modal" role="dialog" aria-modal="true" aria-labelledby="tk-modal-bill-id" class="w-[90vw] max-w-[560px] max-h-[85dvh] flex flex-col bg-[#262626] border-l-4 border-[#ef4444] rounded-lg opacity-0 translate-y-5 transition-all duration-250 ease-out">
    <!-- Header -->
    <div class="flex-shrink-0 p-6 md:p-8 pb-4 flex items-start justify-between gap-4">
      <div>
        <h3 id="tk-modal-bill-id" class="text-[#ef4444] font-black text-2xl tracking-[-0.02em] mb-2"></h3>
        <p id="tk-modal-bill-title" class="text-white font-bold text-lg"></p>
      </div>
      <button id="tk-bill-close" class="text-[#737373] hover:text-white focus-visible:text-white transition-colors text-xl leading-none cursor-pointer flex-shrink-0 w-11 h-11 flex items-center justify-center rounded" aria-label="Close">&times;</button>
    </div>

    <!-- Scrollable body -->
    <div class="overflow-y-auto flex-1 min-h-0 px-6 md:px-8 py-2">
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm mb-6">
        <div>
          <span class="text-[#737373]">Status:</span>
          <span id="tk-modal-bill-status" class="text-[#fbbf24] font-bold ml-1"></span>
        </div>
        <div id="tk-modal-last-action-row">
          <span class="text-[#737373]">Last Action:</span>
          <span id="tk-modal-bill-last-action" class="text-[#a3a3a3] ml-1"></span>
        </div>
      </div>
      <p id="tk-modal-bill-description" class="text-[#a3a3a3] text-sm leading-relaxed"></p>
    </div>

    <!-- Footer -->
    <div class="flex-shrink-0 p-6 md:p-8 pt-4 border-t border-[#404040]">
      <a id="tk-modal-bill-link" href="#" target="_blank" rel="noopener" class="text-[#fbbf24] hover:text-[#fcd34d] text-sm font-medium transition-colors">
        Read full text on scstatehouse.gov<span class="sr-only"> (opens in new tab)</span> &rarr;&#xFE0E;
      </a>
    </div>
  </div>
</div>

<!-- Section 4: Bill Gaps - What's Missing -->
<div>
  <h3 class="text-white font-extrabold text-xl md:text-2xl tracking-[-0.02em] mb-3">
    What's Missing from the Pending Bills
  </h3>
  <p class="text-[#d4d4d4] text-base leading-[1.7] mb-8">
    All three SC bills are a start. But none of them close these gaps.
  </p>

  <div class="grid md:grid-cols-2 gap-5">
    {billGaps.map((g) => (
      <div class="bg-[rgba(163,163,163,0.12)] rounded-xl border-l-[3px] border-[#ef4444] p-5 flex flex-col">
        <h4 class="text-white font-bold text-base mb-2">{g.gap}</h4>
        <p class="text-[#a3a3a3] text-sm leading-[1.6]">{g.detail}</p>
      </div>
    ))}
  </div>
</div>

<style>
  /* Accordion animation (matches FAQ pattern) */
  .legal-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 300ms ease-out;
  }

  .legal-inner {
    overflow: hidden;
  }

  details[open] .legal-content {
    grid-template-rows: 1fr;
  }

  /* Red border when open */
  details[open].legal-details {
    border-color: #ef4444;
  }

  /* Rotate + to x */
  details[open] .legal-icon {
    transform: rotate(45deg);
  }

  /* Smooth close animation */
  details.closing .legal-content {
    grid-template-rows: 0fr;
  }

  details.closing.legal-details {
    border-color: #262626;
  }

  details.closing .legal-icon {
    transform: rotate(0deg);
  }
</style>

<script>
  let legalController: AbortController | null = null;

  function initLegalTab() {
    legalController?.abort();
    legalController = new AbortController();

    // Accordion close animation
    document.querySelectorAll<HTMLDetailsElement>('.legal-details').forEach((details) => {
      const summary = details.querySelector('summary');
      summary?.addEventListener('click', (e) => {
        if (details.hasAttribute('open')) {
          e.preventDefault();
          details.classList.add('closing');
          setTimeout(() => {
            details.classList.remove('closing');
            details.removeAttribute('open');
          }, 300);
        }
      });
    });
  }

  initLegalTab();
  document.addEventListener('astro:after-swap', initLegalTab);
</script>

<script define:vars={{ bills }}>
  const backdrop = document.getElementById('tk-bill-backdrop');
  const modal = document.getElementById('tk-bill-modal');
  const closeBtn = document.getElementById('tk-bill-close');
  var previouslyFocused = null;

  function openTkModal(index) {
    const bill = bills[index];
    if (!bill) return;
    previouslyFocused = document.activeElement;

    document.getElementById('tk-modal-bill-id').textContent = bill.bill;
    document.getElementById('tk-modal-bill-title').textContent = bill.title;
    document.getElementById('tk-modal-bill-status').textContent = bill.status;
    document.getElementById('tk-modal-bill-description').textContent = bill.description;
    document.getElementById('tk-modal-bill-link').href = bill.url;

    const lastActionRow = document.getElementById('tk-modal-last-action-row');
    const lastAction = document.getElementById('tk-modal-bill-last-action');
    if (bill.lastAction) {
      lastAction.textContent = bill.lastAction;
      lastActionRow.style.display = '';
    } else {
      lastActionRow.style.display = 'none';
    }

    backdrop.classList.remove('hidden');
    backdrop.offsetHeight;
    backdrop.classList.add('opacity-100');
    backdrop.classList.remove('opacity-0');

    modal.classList.add('opacity-100', 'translate-y-0');
    modal.classList.remove('opacity-0', 'translate-y-5');

    document.body.style.overflow = 'hidden';

    setTimeout(function() {
      document.getElementById('tk-bill-close')?.focus();
    }, 250);
  }

  function closeTkModal() {
    modal.classList.remove('opacity-100', 'translate-y-0');
    modal.classList.add('opacity-0', 'translate-y-5');

    backdrop.classList.remove('opacity-100');
    backdrop.classList.add('opacity-0');

    setTimeout(function() {
      backdrop.classList.add('hidden');
      document.body.style.overflow = '';
      if (previouslyFocused) {
        previouslyFocused.focus();
      }
      previouslyFocused = null;
    }, 200);
  }

  // Focus trap
  modal?.addEventListener('keydown', function(e) {
    if (e.key !== 'Tab') return;
    var focusable = modal.querySelectorAll('button, a[href], [tabindex]:not([tabindex="-1"])');
    if (focusable.length === 0) return;
    var first = focusable[0];
    var last = focusable[focusable.length - 1];

    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });

  // Card click handlers
  document.querySelectorAll('.tk-bill-card').forEach(function(card) {
    card.addEventListener('click', function() {
      var index = parseInt(card.getAttribute('data-tk-bill'));
      openTkModal(index);
    });
  });

  // Close handlers
  closeBtn?.addEventListener('click', closeTkModal);
  backdrop?.addEventListener('click', function(e) {
    if (e.target === backdrop) closeTkModal();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !backdrop?.classList.contains('hidden')) {
      closeTkModal();
    }
  });
</script>
