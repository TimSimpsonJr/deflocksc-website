---
---

<section aria-labelledby="hero-heading" class="bg-[#0d0d0d] min-h-[88vh] flex flex-col pt-[72px] pb-16 relative overflow-hidden">
  <!-- Subtle gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#171717] via-[#1a1a1a] to-[#171717] opacity-80" aria-hidden="true"></div>

  <!-- Camera poles and animated light cones -->
  <div class="absolute top-[22%] md:top-6 lg:-top-5 left-1/2 -translate-x-1/2 pointer-events-none" style="z-index: 1;" aria-hidden="true">
    <div class="relative w-[650px] md:w-[1000px] lg:w-[1300px]">

      <!-- Camera image -->
      <picture>
        <source
          type="image/webp"
          srcset="/hero-cameras-650w.webp 650w, /hero-cameras-1000w.webp 1000w, /hero-cameras-1300w.webp 1300w, /hero-cameras-2600w.webp 2600w"
          sizes="(max-width: 767px) 650px, (max-width: 1023px) 1000px, 1300px" />
        <img
          src="/hero-cameras-1300w.png"
          srcset="/hero-cameras-650w.png 650w, /hero-cameras-1000w.png 1000w, /hero-cameras-1300w.png 1300w, /hero-cameras-2600w.png 2600w"
          sizes="(max-width: 767px) 650px, (max-width: 1023px) 1000px, 1300px"
          width="1300" height="752"
          alt="" aria-hidden="true"
          class="max-w-none w-full h-auto"
          style="filter: blur(3px) brightness(0.90); mask-image: linear-gradient(to bottom, black 50%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);" />
      </picture>

      <!-- Animated light cones (on top of camera image, overflow visible so cones aren't clipped at image edges) -->
      <svg id="hero-cones" class="absolute inset-0 w-full h-full"
        viewBox="0 0 5098 2949" style="overflow: visible;" aria-hidden="true">
        <defs>
          <linearGradient id="cone-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="white" stop-opacity="0.3" />
            <stop offset="100%" stop-color="white" stop-opacity="0" />
          </linearGradient>
          <filter id="cone-blur" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur in="SourceGraphic" stdDeviation="30" />
          </filter>
        </defs>
        <polygon class="hero-cone hero-cone-outer" data-origin="53 1982"
          points="53,1982 -647,5982 753,5982" fill="url(#cone-grad)" filter="url(#cone-blur)" />
        <polygon class="hero-cone hero-cone-outer" data-origin="540 1804"
          points="540,1804 -160,5804 1240,5804" fill="url(#cone-grad)" filter="url(#cone-blur)" />
        <polygon class="hero-cone" data-origin="1206 1683"
          points="1206,1683 506,5683 1906,5683" fill="url(#cone-grad)" filter="url(#cone-blur)" />
        <polygon class="hero-cone" data-origin="2312 1389"
          points="2312,1389 1612,5389 3012,5389" fill="url(#cone-grad)" filter="url(#cone-blur)" />
        <polygon class="hero-cone" data-origin="3891 1683"
          points="3891,1683 3191,5683 4591,5683" fill="url(#cone-grad)" filter="url(#cone-blur)" />
        <polygon class="hero-cone hero-cone-outer" data-origin="4557 1804"
          points="4557,1804 3857,5804 5257,5804" fill="url(#cone-grad)" filter="url(#cone-blur)" />
        <polygon class="hero-cone hero-cone-outer" data-origin="5044 1982"
          points="5044,1982 4344,5982 5744,5982" fill="url(#cone-grad)" filter="url(#cone-blur)" />
      </svg>
    </div>
  </div>

  <!-- Glitch scan bars -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="glitch-bar absolute left-0 right-0 h-[2px] bg-[rgba(220,38,38,0.15)]"></div>
    <div class="glitch-bar2 absolute left-0 right-0 h-[1px] bg-[rgba(255,255,255,0.04)]"></div>
  </div>

  <!-- Top metadata bar -->
  <div class="relative z-10 px-6 md:px-12 flex justify-between items-start pointer-events-none" aria-hidden="true">
    <div class="text-[9px] uppercase tracking-[0.12em] leading-[1.8]">
      <div class="text-[#666]">Subject</div>
      <div class="text-[#999]">Automated License Plate Readers</div>
      <div class="text-[#666] mt-1">Jurisdiction</div>
      <div class="text-[#999]">State of South Carolina</div>
    </div>
    <div class="text-[9px] uppercase tracking-[0.12em] leading-[1.8] text-right">
      <div class="text-[#666]">Status</div>
      <div class="text-[#dc2626]">Unregulated · Active Deployment</div>
      <div class="text-[#666] mt-1">Record Count</div>
      <div class="text-[#999]">422,000,000+ Reads</div>
    </div>
  </div>

  <!-- Spacer: pushes content to bottom, minimum 3rem gap -->
  <div class="flex-grow min-h-[3rem]"></div>

  <!-- Bottom content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-12" style="text-shadow: 0 2px 16px rgba(0,0,0,0.6);">
    <div class="max-w-[680px]">
      <div class="w-8 h-[2px] bg-[#dc2626] mb-8" aria-hidden="true"></div>
      <h1 id="hero-heading" class="text-white font-bold text-3xl md:text-5xl lg:text-6xl tracking-[-0.02em] leading-[1.1] mb-4">
        In 1984, the Thought Police weren't looking for criminals. Neither is <span class="text-[#dc2626]">Flock Safety</span>
      </h1>
      <p class="text-[#d4d4d4] font-semibold text-xl md:text-2xl mb-4 leading-snug">
        99% of the plates they scan belong to people suspected of nothing.
      </p>
      <p class="text-[#909090] text-base md:text-[15px] leading-[1.65] max-w-[540px] mb-8" style="text-shadow: 0 1px 8px rgba(0,0,0,0.9), 0 2px 20px rgba(0,0,0,0.8);">
        242 cameras are watching Upstate South Carolina right now. Every car that passes gets photographed. That data goes into a national network. And nobody voted on any of it.
      </p>
      <button type="button" data-open-action
        class="bg-[#dc2626] hover:bg-[#b91c1c] text-white font-bold text-xs uppercase tracking-[0.08em] px-8 py-3.5 transition-colors cursor-pointer">
        Contact Your Reps
      </button>
    </div>
  </div>
</section>

<style>
  @keyframes glitch-scan {
    0%   { top: -2px; opacity: 0; }
    5%   { opacity: 1; }
    95%  { opacity: 0.3; }
    100% { top: 100%; opacity: 0; }
  }
  @keyframes glitch-scan2 {
    0%   { top: -1px; }
    100% { top: 100%; }
  }
  .glitch-bar  { animation: glitch-scan  8s linear infinite; }
  .glitch-bar2 { animation: glitch-scan2 5s linear infinite 2s; }
  @media (prefers-reduced-motion: reduce) {
    .glitch-bar, .glitch-bar2 { animation: none; }
  }

  @keyframes cone-sweep {
    0%   { transform: rotate(-20deg); animation-timing-function: ease-in-out; }
    38%  { transform: rotate(18deg);  animation-timing-function: cubic-bezier(0.7, 0, 0.3, 1); }
    43%  { transform: rotate(-8deg);  animation-timing-function: linear; }
    53%  { transform: rotate(-8deg);  animation-timing-function: ease-in-out; }
    83%  { transform: rotate(20deg);  animation-timing-function: cubic-bezier(0.7, 0, 0.3, 1); }
    88%  { transform: rotate(2deg);   animation-timing-function: linear; }
    95%  { transform: rotate(2deg);   animation-timing-function: ease-in-out; }
    100% { transform: rotate(-20deg); }
  }

  .hero-cone {
    animation: cone-sweep var(--dur, 12s) var(--del, 0s) infinite;
    will-change: transform;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .hero-cone-outer {
    display: block;
  }

  @media (max-width: 767px) {
    .hero-cone-outer {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-cone {
      animation: none;
    }
  }
</style>

<script>
  document.querySelectorAll('.hero-cone').forEach((cone) => {
    const origin = cone.getAttribute('data-origin') || '0 0';
    const [cx, cy] = origin.split(' ');
    const el = cone as SVGElement;
    el.style.transformOrigin = `${cx}px ${cy}px`;
    el.style.setProperty('--dur', `${10 + Math.random() * 8}s`);
    el.style.setProperty('--del', `${-Math.random() * 16}s`);
    if (Math.random() > 0.5) {
      el.style.animationDirection = 'reverse';
    }
  });
</script>
