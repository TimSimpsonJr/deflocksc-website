---
---

<footer class="bg-[#171717] border-t border-[rgba(255,255,255,0.07)] py-16">
  <div data-reveal="up" class="max-w-6xl mx-auto px-6">

    <!-- Campaign CTA -->
    <div class="bg-[#1a1a1a] border border-[rgba(255,255,255,0.07)] p-6 md:p-8 mb-12 flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8">
      <div class="flex-1">
        <p class="label-mono-compact text-[#dc2626] mb-2">Support the campaign</p>
        <p class="text-[#d4d4d4] text-base leading-relaxed">We're putting "Big Brother Is Watching You" signs in front of every Flock camera in Upstate SC. Every shirt, poster, and sponsorship funds the next batch of signs.</p>
      </div>
      <a href="/support" class="inline-block bg-[#dc2626] hover:bg-[#b91c1c] text-white font-bold text-xs uppercase tracking-[0.08em] px-6 py-3 transition-colors flex-shrink-0 text-center">Support the Campaign</a>
    </div>

    <div class="grid md:grid-cols-3 gap-12">
      <!-- About -->
      <div>
        <h3 class="text-white font-extrabold text-sm uppercase tracking-[0.1em] mb-4">About DeflockSC</h3>
        <p class="text-[#a3a3a3] text-base leading-relaxed mb-3">DeflockSC is a group of South Carolinians who think you deserve a vote before your government puts surveillance cameras on your streets. We don't belong to any political party. We just don't think the government should track where you drive.</p>
        <p class="text-[#a3a3a3] text-base">Questions or want to get involved? Reach us at <a href="mailto:deflocksc@proton.me" class="text-[#fbbf24] hover:text-[#fcd34d] transition-colors">deflocksc@proton.me</a></p>
      </div>

      <!-- Site links -->
      <nav aria-label="Site pages">
        <h3 class="text-white font-extrabold text-sm uppercase tracking-[0.1em] mb-4">Explore</h3>
        <ul class="grid grid-cols-2 gap-x-6 gap-y-2.5 font-['DM_Mono',monospace] text-[13px]">
          <li><a href="/#how-it-works" class="text-[#a3a3a3] hover:text-[#e8e8e8] transition-colors">How ALPR Works</a></li>
          <li><a href="/toolkit" class="text-[#a3a3a3] hover:text-[#e8e8e8] transition-colors">Citizen Toolkit</a></li>
          <li><a href="/support" class="text-[#a3a3a3] hover:text-[#e8e8e8] transition-colors">Support</a></li>
          <li><a href="/#camera-map" class="text-[#a3a3a3] hover:text-[#e8e8e8] transition-colors">SC Camera Map</a></li>
          <li><a href="/blog" class="text-[#a3a3a3] hover:text-[#e8e8e8] transition-colors">Blog</a></li>
          <li><a href="/#bill-tracker" class="text-[#a3a3a3] hover:text-[#e8e8e8] transition-colors">Bill Tracker</a></li>
          <li><a href="/#faq" class="text-[#a3a3a3] hover:text-[#e8e8e8] transition-colors">FAQ</a></li>
        </ul>
      </nav>

      <!-- External links -->
      <nav aria-label="External resources">
        <h3 class="text-white font-extrabold text-sm uppercase tracking-[0.1em] mb-4">Resources</h3>
        <ul class="space-y-2 text-base">
          <li><a href="https://deflock.org" target="_blank" rel="noopener" class="text-[#fbbf24] hover:text-[#fcd34d] transition-colors">Deflock.org<span class="sr-only"> (opens in new tab)</span></a></li>
          <li><a href="https://www.eff.org/issues/license-plates" target="_blank" rel="noopener" class="text-[#fbbf24] hover:text-[#fcd34d] transition-colors">EFF License Plate Reader Hub<span class="sr-only"> (opens in new tab)</span></a></li>
          <li><a href="https://ij.org/issues/private-property/plate-privacy/" target="_blank" rel="noopener" class="text-[#fbbf24] hover:text-[#fcd34d] transition-colors">Institute for Justice — Plate Privacy Project<span class="sr-only"> (opens in new tab)</span></a></li>
          <li><a href="https://banthecams.org" target="_blank" rel="noopener" class="text-[#fbbf24] hover:text-[#fcd34d] transition-colors">Ban The Cams<span class="sr-only"> (opens in new tab)</span></a></li>
        </ul>
      </nav>

    </div>

    <div class="mt-12 pt-8 border-t border-[rgba(255,255,255,0.07)] text-center text-[#a3a3a3] text-xs">
      &copy; {new Date().getFullYear()} DeflockSC. All rights reserved.
    </div>
  </div>
</footer>
