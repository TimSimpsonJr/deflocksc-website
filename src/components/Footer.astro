<footer class="bg-[#171717] border-t border-[rgba(255,255,255,0.07)] py-16">
  <div data-reveal="up" class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-12">
      <!-- About -->
      <div>
        <h3 class="text-white font-extrabold text-sm uppercase tracking-[0.1em] mb-4">About DeflockSC</h3>
        <p class="text-[#a3a3a3] text-base leading-relaxed">DeflockSC is a group of South Carolinians who think you deserve a vote before your government puts surveillance cameras on your streets. We don't belong to any political party. We just don't think the government should track where you drive.</p>
      </div>

      <!-- Site links -->
      <nav aria-label="Site pages">
        <h3 class="text-white font-extrabold text-sm uppercase tracking-[0.1em] mb-4">Explore</h3>
        <ul class="grid grid-cols-2 gap-x-6 gap-y-2.5 font-['DM_Mono',monospace] text-[13px]">
          <li><a href="/#how-it-works" class="text-[#737373] hover:text-[#e8e8e8] transition-colors">How ALPR Works</a></li>
          <li><a href="/toolkit" class="text-[#737373] hover:text-[#e8e8e8] transition-colors">Citizen Toolkit</a></li>
          <li><a href="/shop" class="text-[#737373] hover:text-[#e8e8e8] transition-colors">Shop</a></li>
          <li><a href="/#camera-map" class="text-[#737373] hover:text-[#e8e8e8] transition-colors">SC Camera Map</a></li>
          <li><a href="/blog" class="text-[#737373] hover:text-[#e8e8e8] transition-colors">Blog</a></li>
          <li><a href="/#bill-tracker" class="text-[#737373] hover:text-[#e8e8e8] transition-colors">Bill Tracker</a></li>
          <li><a href="/#faq" class="text-[#737373] hover:text-[#e8e8e8] transition-colors">FAQ</a></li>
        </ul>
      </nav>

      <!-- External links -->
      <nav aria-label="External resources">
        <h3 class="text-white font-extrabold text-sm uppercase tracking-[0.1em] mb-4">Resources</h3>
        <ul class="space-y-2 text-base">
          <li><a href="https://deflock.org" target="_blank" rel="noopener" class="text-[#fbbf24] hover:text-[#fcd34d] transition-colors">Deflock.org — community camera map<span class="sr-only"> (opens in new tab)</span></a></li>
          <li><a href="https://www.eff.org/issues/license-plates" target="_blank" rel="noopener" class="text-[#fbbf24] hover:text-[#fcd34d] transition-colors">EFF License Plate Reader Hub<span class="sr-only"> (opens in new tab)</span></a></li>
          <li><a href="https://ij.org/issues/private-property/plate-privacy/" target="_blank" rel="noopener" class="text-[#fbbf24] hover:text-[#fcd34d] transition-colors">Institute for Justice — Plate Privacy Project<span class="sr-only"> (opens in new tab)</span></a></li>
          <li><a href="https://banthecams.org" target="_blank" rel="noopener" class="text-[#fbbf24] hover:text-[#fcd34d] transition-colors">Ban The Cams<span class="sr-only"> (opens in new tab)</span></a></li>
        </ul>
      </nav>

    </div>

    <div class="mt-12 pt-8 border-t border-[rgba(255,255,255,0.07)] text-center text-[#a3a3a3] text-xs">
      &copy; {new Date().getFullYear()} DeflockSC. All rights reserved.
    </div>
  </div>
</footer>
