---
import speakingData from '../data/toolkit-speaking.json';

/**
 * Highlight [PLACEHOLDER] markers in talk track text with amber spans.
 */
function highlightPlaceholders(text: string): string {
  const highlighted = text.replace(/\[([A-Z\s\/]+)\]/g, '<span class="text-[#fbbf24] font-semibold">[$1]</span>');
  // Split on double-newlines into separate <p> tags for readability
  return highlighted
    .split('\n\n')
    .map((p) => `<p>${p}</p>`)
    .join('');
}
---

<!-- Intro + Tips -->
<div class="mb-12">
  <p class="label-mono text-[#a3a3a3] mb-3">Public Comment</p>
  <h2 class="text-[#e8e8e8] font-bold text-xl md:text-2xl tracking-[-0.02em] mb-4">
    Speak at a Council Meeting
  </h2>
  <p class="text-[#d4d4d4] text-base leading-[1.7] mb-6">
    {speakingData.intro}
  </p>

  <!-- Numbered tips -->
  <div class="space-y-4">
    {speakingData.tips.map((tip, i) => (
      <div class="flex items-start gap-4 text-[#a3a3a3] text-base leading-[1.7]">
        <span class="font-['DM_Mono',monospace] text-[11px] text-[#a3a3a3] tracking-[0.05em] mt-[3px] flex-shrink-0">{String(i + 1).padStart(2, '0')}</span>
        <span>{tip}</span>
      </div>
    ))}
  </div>
</div>

<!-- Talk Track -->
<div class="mb-16">
  <p class="label-mono text-[#a3a3a3] mb-3">Talk Track</p>
  <h2 class="text-[#e8e8e8] font-bold text-xl md:text-2xl tracking-[-0.02em] mb-2">
    {speakingData.talkTrack.title}
  </h2>
  <p class="text-[#a3a3a3] text-sm mb-6">
    Read this straight or adapt it. The timing markers help you stay under three minutes.
  </p>

  <!-- 1px-gap vertical grid -->
  <div class="bg-[rgba(255,255,255,0.07)]" style="display:grid;gap:1px">
    {speakingData.talkTrack.sections.map((section, i) => (
      <div class="bg-[#111111] p-6 relative overflow-hidden">
        <!-- DM Mono overline: dot + label + timing -->
        <div class="flex items-center gap-3 mb-4">
          <span class="w-[5px] h-[5px] rounded-full bg-[#fbbf24] flex-shrink-0" aria-hidden="true"></span>
          <span class="label-mono-tight text-[#a3a3a3]">
            {section.label}
          </span>
          <span class="label-mono-tight text-[#fbbf24]">
            {section.timing}
          </span>
        </div>
        <div
          class="text-[#d4d4d4] text-base leading-[1.7] space-y-3"
          set:html={highlightPlaceholders(section.text)}
        />
        <!-- Ghost label -->
        <span class="absolute bottom-3 right-5 font-bold text-[rgba(255,255,255,0.025)] text-[2.5rem] leading-none pointer-events-none select-none" aria-hidden="true">
          {String(i + 1).padStart(2, '0')}
        </span>
      </div>
    ))}
  </div>
</div>

<!-- Rebuttals — sidebar + panel -->
<div class="mb-16">
  <p class="label-mono text-[#a3a3a3] mb-3">Rebuttals</p>
  <h2 class="text-[#e8e8e8] font-bold text-xl md:text-2xl tracking-[-0.02em] mb-2">
    If They Push Back
  </h2>
  <p class="text-[#a3a3a3] text-sm mb-6">
    Common claims you'll hear from council members and how to respond.
  </p>

  <div class="rebuttal-layout md:grid md:grid-cols-[280px_1fr] bg-[rgba(255,255,255,0.07)]" style="gap:1px">
    <!-- Claims sidebar -->
    <div class="bg-[#111111]">
      <div class="label-mono text-[#a3a3a3] px-6 py-3 border-b border-[rgba(255,255,255,0.04)]">
        Claims
      </div>
      {speakingData.rebuttals.map((r, i) => (
        <button
          type="button"
          class:list={['rebuttal-btn sidebar-btn w-full text-left px-6 py-4 text-sm font-medium leading-[1.35] border-b border-[rgba(255,255,255,0.04)] cursor-pointer', i === 0 ? 'sidebar-active' : '']}
          data-rebuttal={i}
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          &ldquo;{r.claim}&rdquo;
        </button>
      ))}
    </div>

    <!-- Response panel -->
    <div class="bg-[#111111] p-8 md:p-10">
      {speakingData.rebuttals.map((r, i) => (
        <div class:list={['rebuttal-panel', i !== 0 && 'hidden']} data-rebuttal-panel={i}>
          <p class="label-mono-tight text-[#a3a3a3] mb-2">Rebuttal {String(i + 1).padStart(2, '0')}</p>
          <h3 class="text-[#e8e8e8] font-bold text-lg mb-4">&ldquo;{r.claim}&rdquo;</h3>
          <p class="text-[#a3a3a3] text-base leading-[1.7]">{r.response}</p>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- Council Handout Download -->
<div class="border-t border-[rgba(255,255,255,0.07)] pt-10">
  <h2 class="text-[#e8e8e8] font-bold text-lg mb-4">Council Handout</h2>
  <p class="text-[#a3a3a3] text-base leading-[1.7] mb-4">
    A one-page PDF with key facts and sources. Print copies for each council member
    and hand them to the clerk before you speak.
  </p>
  <a
    href="/toolkit/speaking/council-handout.pdf"
    class="inline-flex items-center bg-[#dc2626] hover:bg-[#b91c1c] text-white font-bold text-sm uppercase tracking-[0.1em] px-5 py-2.5 transition-colors"
    download
  >
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    Download Council Handout
  </a>
</div>

<script>
  function initSpeakingTab() {
    // Rebuttal sidebar selection
    const rebuttalBtns = document.querySelectorAll<HTMLButtonElement>('.rebuttal-btn');
    const rebuttalPanels = document.querySelectorAll<HTMLElement>('.rebuttal-panel');

    rebuttalBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = btn.getAttribute('data-rebuttal');
        rebuttalBtns.forEach(b => {
          b.classList.remove('sidebar-active');
          b.setAttribute('aria-selected', 'false');
        });
        rebuttalPanels.forEach(p => p.classList.add('hidden'));
        btn.classList.add('sidebar-active');
        btn.setAttribute('aria-selected', 'true');
        document.querySelector(`.rebuttal-panel[data-rebuttal-panel="${idx}"]`)?.classList.remove('hidden');
      });
    });
  }

  initSpeakingTab();
  document.addEventListener('astro:after-swap', initSpeakingTab);
</script>
