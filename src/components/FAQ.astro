---
const faqs = [
  {
    question: '"Don\'t these cameras only catch criminals?"',
    lead: '99% of the plates Flock scans belong to people not suspected of anything.',
    rest: 'The cameras watch everyone. In Greenville, the system flagged an innocent woman\'s rental car as stolen. Police drew their weapons and handcuffed her. She wasn\'t a criminal.',
  },
  {
    question: '"If you have nothing to hide, why worry?"',
    lead: 'The 4th Amendment protects everyone from government searches without cause, not just people with something to hide.',
    rest: 'You don\'t have to prove your innocence to deserve privacy.',
  },
  {
    question: '"Doesn\'t this reduce crime?"',
    lead: 'Austin ran its own city audit and couldn\'t find evidence the cameras reduce crime.',
    rest: 'We want public safety too. Show us evidence this actually delivers it and we\'ll listen.',
  },
  {
    question: '"Isn\'t the data protected?"',
    lead: 'Flock\'s own CEO admitted in 2025 they didn\'t have proper safeguards.',
    rest: 'Right here in SC, a law enforcement officer used SLED\'s database to look up his own car, then changed the record. When a reporter asked SLED for more recent misconduct cases, they refused to answer. That\'s what "protected" looks like in practice.',
  },
  {
    question: '"Isn\'t this anti-police?"',
    lead: 'In Hays County, TX and Staunton, VA, the decision to cancel Flock had police support.',
    rest: 'A Staunton chief with 41 years on the job called residents raising concerns "democracy in action." A conservative Republican state rep from just outside Greenville put it plainly: "I\'ve run into individuals in law enforcement who have taken advantage of their positions. The potential is certainly out there."',
  },
];
---

<section id="faq" aria-labelledby="faq-heading" class="bg-[#171717] py-20 md:py-28">
  <div class="max-w-4xl mx-auto px-6">
    <h2 id="faq-heading" class="text-white font-extrabold text-2xl md:text-4xl tracking-[-0.02em] mb-10">
      But what about&hellip;
    </h2>

    <div class="space-y-3">
      {faqs.map((faq, i) => (
        <details class="faq-item group border-l-[3px] border-[#262626]" data-faq={i} open={i === 0 || undefined}>
          <summary class="flex items-center justify-between cursor-pointer py-4 px-5 list-none [&::-webkit-details-marker]:hidden">
            <span class="text-white font-bold text-base pr-4">{faq.question}</span>
            <span class="faq-icon text-[#ef4444] font-bold text-xl flex-shrink-0 transition-transform duration-300">+</span>
          </summary>
          <div class="faq-content">
            <div class="faq-inner px-5 pb-5">
              <p class="text-[#a3a3a3] text-base leading-[1.7]"><strong class="text-[#d4d4d4]">{faq.lead}</strong> {faq.rest}</p>
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  /* Smooth open/close animation using grid trick */
  .faq-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 300ms ease-out;
  }

  .faq-inner {
    overflow: hidden;
  }

  details[open] .faq-content {
    grid-template-rows: 1fr;
  }

  /* Red border when open */
  details[open] {
    border-color: #ef4444;
  }

  /* Rotate + to x (toggle indicator) */
  details[open] .faq-icon {
    transform: rotate(45deg);
  }

  /* Prevent instant close — handled by JS */
  details.closing .faq-content {
    grid-template-rows: 0fr;
  }

  details.closing {
    border-color: #262626;
  }

  details.closing .faq-icon {
    transform: rotate(0deg);
  }
</style>

<script>
  // Handle smooth close animation for <details> elements
  document.querySelectorAll('.faq-item').forEach(details => {
    const summary = details.querySelector('summary');

    summary?.addEventListener('click', (e) => {
      // If currently open, animate close
      if (details.hasAttribute('open')) {
        e.preventDefault();
        details.classList.add('closing');

        // Wait for animation to finish, then actually close
        setTimeout(() => {
          details.classList.remove('closing');
          details.removeAttribute('open');
        }, 300);
      }
    });
  });
</script>
