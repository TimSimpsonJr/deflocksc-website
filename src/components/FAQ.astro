---
const faqs = [
  {
    question: '"Don\'t these cameras only catch criminals?"',
    lead: '99.5% of the plates Flock scans belong to people not suspected of anything.',
    rest: 'Flock\'s cameras don\'t just record plate numbers. They log vehicle make, color, and travel patterns for every car that passes. That\'s a record of where everyone goes.',
    source: 'Source: <a href="https://www.eff.org/pages/automated-license-plate-readers-alpr" target="_blank" rel="noopener" class="text-[#fbbf24] underline">EFF</a>',
  },
  {
    question: '"If you have nothing to hide, why worry?"',
    lead: 'The 4th Amendment protects everyone from government searches without cause, not just people with something to hide.',
    rest: 'These cameras log every trip your family makes. Every school run. Every doctor visit. Every church service. Flock\'s system doesn\'t just record where you went. It builds a profile of your normal driving. Change your routine and the system can flag you to police. No warrant. No suspicion. Just an algorithm that decided you drove somewhere new.',
  },
  {
    question: '"Doesn\'t this reduce crime?"',
    lead: 'Austin ran its own city audit and couldn\'t find evidence the cameras reduce crime.',
    rest: 'These systems cost cities hundreds of thousands of dollars a year. Greenville paid with federal civil asset forfeiture money that bypassed normal council appropriations. We want public safety too. Show us the return on that investment.',
    source: 'Source: <a href="https://www.eff.org/deeplinks/2025/06/victory-austin-organizers-cancel-citys-flock-alpr-contract" target="_blank" rel="noopener" class="text-[#fbbf24] underline">EFF</a> <span class="mx-1">&middot;</span> <a href="https://www.kut.org/austin/2025-06-04/austin-tx-automatic-license-reader-program-police-data-privacy-flock" target="_blank" rel="noopener" class="text-[#fbbf24] underline">KUT Radio</a>',
  },
  {
    question: '"Isn\'t the data protected?"',
    lead: 'Flock couldn\'t even explain how data sharing got turned back on in Ventura County after the agency disabled it.',
    rest: 'Right here in SC, a law enforcement officer used SLED\'s database to look up his own car, then changed the record. When a reporter asked SLED about misconduct, they refused to answer. That\'s what protected looks like in practice.',
    source: 'Sources: <a href="https://www.cbsnews.com/losangeles/news/flock-license-plate-readers-shared-data-with-out-of-state-federal-agencies/" target="_blank" rel="noopener" class="text-[#fbbf24] underline">CBS Los Angeles</a> <span class="mx-1">&middot;</span> <a href="https://www.postandcourier.com/news/alpr-cameras-south-carolina-flock-safety-license-plate-readers/article_787a262a-dbd2-11ee-a901-634acead588b.html" target="_blank" rel="noopener" class="text-[#fbbf24] underline">Post and Courier</a>',
  },
  {
    question: '"Isn\'t this anti-police?"',
    lead: 'A Virginia police chief with 41 years on the job helped cancel his city\'s Flock contract.',
    rest: 'Chief Jim Williams of Staunton called residents raising privacy concerns "democracy in action." Back home, conservative Republican Rep. Garry Smith of Simpsonville has the same concern: "I\'ve run into individuals in law enforcement who have taken advantage of their positions. The potential is certainly out there."',
    source: 'Sources: <a href="https://augustafreepress.com/news/staunton-to-cancel-flock-safety-camera-contract-doesnt-agree-with-ideology-of-ceo/" target="_blank" rel="noopener" class="text-[#fbbf24] underline">Augusta Free Press</a> <span class="mx-1">&middot;</span> <a href="https://www.postandcourier.com/greenville/news/greenville-adding-more-cameras-to-read-license-plates-raising-questions-of-oversight-privacy/article_4cf2761a-4157-11eb-98b9-9b7e9434164e.html" target="_blank" rel="noopener" class="text-[#fbbf24] underline">Post and Courier</a>',
  },
];
---

<section id="faq" aria-labelledby="faq-heading" class="bg-[#161616] overflow-hidden">

  <!-- Section header -->
  <div class="px-6 md:px-12 pt-14 pb-6 border-b border-[rgba(255,255,255,0.07)]">
    <p data-reveal="up" class="font-['DM_Mono',monospace] text-[10px] uppercase tracking-[0.18em] text-[#737373] mb-3">Common objections</p>
    <h2 id="faq-heading" data-reveal="up" data-reveal-delay="1" class="text-[#e8e8e8] font-bold text-[clamp(1.8rem,3.5vw,2.8rem)] tracking-[-0.025em] leading-[1.05]">
      But what about&hellip;
    </h2>
  </div>

  <!-- Sidebar + answer panel -->
  <div class="faq-layout md:grid md:grid-cols-[280px_1fr]">

    <!-- Question list -->
    <div data-reveal="left" class="faq-sidebar border-b md:border-b-0 md:border-r border-[rgba(255,255,255,0.07)]">
      <div class="font-['DM_Mono',monospace] text-[9px] uppercase tracking-[0.18em] text-[#737373] px-8 py-4 border-b border-[rgba(255,255,255,0.07)]">
        Questions
      </div>
      {faqs.map((faq, i) => (
        <button
          type="button"
          class:list={['sidebar-btn w-full text-left px-8 py-4 text-base font-medium leading-[1.35] border-b border-[rgba(255,255,255,0.04)] cursor-pointer', i === 0 ? 'sidebar-active' : '']}
          data-faq={i}
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {faq.question}
        </button>
      ))}
    </div>

    <!-- Answer panel -->
    <div data-reveal="right" data-reveal-delay="1" class="faq-answer-panel p-8 md:p-12 flex flex-col justify-center min-h-[320px]">
      {faqs.map((faq, i) => (
        <div class:list={['faq-answer', i !== 0 ? 'hidden' : '']} data-answer={i}>
          <div class="text-[#e8e8e8] font-semibold text-[1.4rem] tracking-[-0.015em] leading-[1.2] mb-5">{faq.question}</div>
          <p class="text-[#a0a0a0] text-[17px] leading-[1.75] max-w-[560px]">
            <strong class="text-[#e8e8e8]">{faq.lead}</strong> {faq.rest}
          </p>
          {faq.source && (
            <p class="text-[#737373] text-xs mt-3" set:html={faq.source} />
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Sidebar styles now in global.css (.sidebar-btn, .sidebar-active) -->

<script>
  const buttons = document.querySelectorAll('.sidebar-btn');
  const answers = document.querySelectorAll('.faq-answer');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = btn.getAttribute('data-faq');
      buttons.forEach(b => {
        b.classList.remove('sidebar-active');
        b.setAttribute('aria-selected', 'false');
      });
      answers.forEach(a => a.classList.add('hidden'));
      btn.classList.add('sidebar-active');
      btn.setAttribute('aria-selected', 'true');
      document.querySelector(`.faq-answer[data-answer="${idx}"]`)?.classList.remove('hidden');
    });
  });
</script>
