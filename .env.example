# Umami Analytics (privacy-friendly, cookie-free)
# Get these values after deploying Umami (e.g. on Railway)
# See: https://umami.is/docs/getting-started

# Your Umami website ID (required to enable analytics)
PUBLIC_UMAMI_WEBSITE_ID=

# URL to the Umami tracking script (defaults to Umami Cloud if omitted)
# PUBLIC_UMAMI_SRC=https://your-umami-instance.up.railway.app/script.js
